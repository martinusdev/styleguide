# Nginx reverse proxy pre MCP server.
# Skopíruj do /etc/nginx/sites-available/mcp-styleguide, uprav server_name
# a vytvor symlink do sites-enabled. SSL pridá `certbot --nginx`.

server {
    listen 80;
    server_name CHANGE_ME.example.com;

    location / {
        proxy_pass http://127.0.0.1:3001;
        proxy_http_version 1.1;

        # MCP používa Server-Sent Events — buffering musí byť vypnutý.
        proxy_set_header Connection '';
        proxy_buffering off;
        proxy_cache off;
        chunked_transfer_encoding on;

        proxy_read_timeout 24h;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
